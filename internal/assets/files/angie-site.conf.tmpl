# Rendered by reality-deployer — 重新配置时会覆盖，请勿手动编辑。
# Angie 内置 ACME（>= 1.5.0），HTTP-01 挑战在 :80。
# 文档: https://en.angie.software/angie/docs/configuration/modules/http/http_acme/

# ACME 客户端注册在 http{} 作用域
acme_client le_{{.ClientID}} {
    account_key /etc/angie/acme/{{.Domain}}.account.key;
    email {{.Email}};
}

# :80 —— ACME HTTP-01 挑战响应 + 跳转 https
server {
    listen 80;
    listen [::]:80;
    server_name {{.Domain}};

    location /.well-known/acme-challenge/ {
        acme_challenge le_{{.ClientID}};
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# :8443（仅回环）—— 真站点：服务 REALITY 回源 / 直连访客
server {
    listen 127.0.0.1:8443 ssl;
    http2 on;
    server_name {{.Domain}};

    # 证书由 ACME 客户端签发，以变量形式引用
    ssl_certificate     $acme_cert_le_{{.ClientID}};
    ssl_certificate_key $acme_cert_key_le_{{.ClientID}};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    root /var/www/{{.Domain}};
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
}
